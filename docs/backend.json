
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the ClientsFinding application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a business lead.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "email": { "type": "string", "format": "email" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "status": { 
          "type": "string", 
          "enum": ["new", "enriching", "ready", "synced", "contacted", "replied"],
          "description": "The current stage in the lead generation pipeline."
        },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "address", "category", "status"]
    },
    "LeadList": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LeadList",
      "type": "object",
      "description": "Represents a custom list of leads.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "count": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "userId", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/leadLists/{leadListId}",
        "definition": {
          "entityName": "LeadList",
          "schema": { "$ref": "#/backend/entities/LeadList" },
          "description": "User lead lists."
        }
      },
      {
        "path": "/users/{userId}/leadLists/{leadListId}/leads/{leadId}",
        "definition": {
          "entityName": "Lead",
          "schema": { "$ref": "#/backend/entities/Lead" },
          "description": "Leads within a specific list."
        }
      }
    ]
  }
}
